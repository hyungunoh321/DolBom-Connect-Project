<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.siheung.careconnect">

    <!-- 인터넷 권한 (FCM 알림, API 통신용) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="돌봄 커넥트"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CareConnect">

        <!-- ★ MainActivity 등록 — 앱 시작점 -->
        <activity
            android:name=".main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".benefits.BenefitsActivity" />
        <!-- 나중에 추가할 화면들 -->
        <!--
        <activity android:name=".benefits.BenefitsActivity" />
        <activity android:name=".reservation.ReservationActivity" />
        <activity android:name=".reservationStatus.ReservationStatusActivity" />
        <activity android:name=".realtime.RealtimeActivity" />
        -->

    </application>

</manifest>